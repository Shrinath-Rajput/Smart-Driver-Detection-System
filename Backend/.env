# ========== SERVER CONFIGURATION ==========
PORT=5002
NODE_ENV=development

# ========== DATABASE CONFIGURATION ==========
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=shrinath1814
DB_NAME=drowsiness_detection

# ========== TWILIO SMS CONFIGURATION ==========
# Get credentials from https://www.twilio.com/console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ========== GOOGLE MAPS CONFIGURATION ==========
GOOGLE_MAPS_API_KEY=your_api_key_here

# ========== DETECTION SETTINGS ==========
ALARM_THRESHOLD=150
CONFIDENCE_THRESHOLD=0.5
FRAME_CHECK_INTERVAL=100
CAMERA_INDEX=0
DISPLAY_ENABLED=false

# ========== PYTHON AI DETECTION SERVICE ==========
# Backend URL for Python service to report detection results
BACKEND_URL=http://localhost:5002
DRIVER_ID=DRIVER_001
DRIVER_NAME=Default Driver
MODEL_PATH=artifacts/drowsiness_model.h5

# ========== GPS SETTINGS ==========
USE_DUMMY_GPS=true
GPS_UPDATE_INTERVAL=5000

# ========== LOGGING ==========
LOG_LEVEL=INFO
LOG_FILE=logs/drowsiness_detection.log

# ========== FEATURES ==========
SEND_SMS=false

