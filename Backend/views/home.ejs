<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Driver Drowsiness Detection - Premium Safety System</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="navbar">
        <div class="container">
            <div class="navbar-brand">
                <h1 class="logo"><i class="fas fa-shield-alt"></i> DriveAlert</h1>
                <p class="tagline">Smart Driver Monitoring</p>
            </div>
            <ul class="nav-menu">
                <li><a href="/" class="nav-link active">Home</a></li>
                <li><a href="/about" class="nav-link">About</a></li>
                <li><a href="/dashboard?driver_id=DRIVER_001" class="nav-link btn-primary">Dashboard</a></li>
                <li><a href="/analyze?driver_id=DRIVER_001" class="nav-link btn-secondary">Analyze</a></li>
            </ul>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero">
        <div class="container">
            <div class="hero-content">
                <h1 class="hero-title">
                    Advanced Driver Drowsiness Detection
                </h1>
                <p class="hero-subtitle">
                    Real-time AI-powered monitoring system that detects drowsiness with 98.5% accuracy
                </p>
                <div class="hero-buttons">
                    <a href="/dashboard?driver_id=DRIVER_001" class="btn btn-lg btn-primary">
                        <i class="fas fa-play-circle"></i> Launch Dashboard
                    </a>
                    <a href="#features" class="btn btn-lg btn-outline">
                        <i class="fas fa-arrow-down"></i> Learn More
                    </a>
                </div>
            </div>
            <div class="hero-image">
                <div class="animated-box">
                    <div class="detection-visual">
                        <div class="face-frame">
                            <i class="fas fa-face-tired"></i>
                        </div>
                        <div class="pulse pulse-1"></div>
                        <div class="pulse pulse-2"></div>
                        <div class="pulse pulse-3"></div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section class="features" id="features">
        <div class="container">
            <h2 class="section-title">Why Choose DriveAlert?</h2>
            <p class="section-subtitle">Comprehensive safety features for professional drivers</p>

            <div class="features-grid">
                <!-- Feature 1 -->
                <div class="feature-card glass-card">
                    <div class="feature-icon">
                        <i class="fas fa-brain"></i>
                    </div>
                    <h3>AI-Powered Detection</h3>
                    <p>Advanced CNN model with 98.5% accuracy in detecting drowsiness and fatigue</p>
                </div>

                <!-- Feature 2 -->
                <div class="feature-card glass-card">
                    <div class="feature-icon">
                        <i class="fas fa-bell"></i>
                    </div>
                    <h3>Instant Alerts</h3>
                    <p>Immediate audio & SMS alerts when drowsiness is detected to prevent accidents</p>
                </div>

                <!-- Feature 3 -->
                <div class="feature-card glass-card">
                    <div class="feature-icon">
                        <i class="fas fa-map-marker-alt"></i>
                    </div>
                    <h3>GPS Tracking</h3>
                    <p>Real-time location tracking with Google Maps integration for emergency response</p>
                </div>

                <!-- Feature 4 -->
                <div class="feature-card glass-card">
                    <div class="feature-icon">
                        <i class="fas fa-chart-line"></i>
                    </div>
                    <h3>Live Dashboard</h3>
                    <p>Comprehensive real-time dashboard with analytics and performance metrics</p>
                </div>

                <!-- Feature 5 -->
                <div class="feature-card glass-card">
                    <div class="feature-icon">
                        <i class="fas fa-video"></i>
                    </div>
                    <h3>Live Video Feed</h3>
                    <p>Real-time webcam monitoring with eye and face detection technology</p>
                </div>

                <!-- Feature 6 -->
                <div class="feature-card glass-card">
                    <div class="feature-icon">
                        <i class="fas fa-history"></i>
                    </div>
                    <h3>Alert History</h3>
                    <p>Complete alert history with timestamps, locations, and incident analysis</p>
                </div>
            </div>
        </div>
    </section>

    <!-- How It Works Section -->
    <section class="how-it-works">
        <div class="container">
            <h2 class="section-title">How It Works</h2>

            <div class="workflow">
                <div class="workflow-step">
                    <div class="step-number">1</div>
                    <div class="step-content">
                        <h3>Webcam Monitoring</h3>
                        <p>System continuously monitors driver through webcam</p>
                    </div>
                </div>

                <div class="workflow-arrow">→</div>

                <div class="workflow-step">
                    <div class="step-number">2</div>
                    <div class="step-content">
                        <h3>Face Detection</h3>
                        <p>Identifies driver's face in real-time</p>
                    </div>
                </div>

                <div class="workflow-arrow">→</div>

                <div class="workflow-step">
                    <div class="step-number">3</div>
                    <div class="step-content">
                        <h3>Eye Analysis</h3>
                        <p>Detects eye closure and blink patterns</p>
                    </div>
                </div>

                <div class="workflow-arrow">→</div>

                <div class="workflow-step">
                    <div class="step-number">4</div>
                    <div class="step-content">
                        <h3>CNN Prediction</h3>
                        <p>AI model predicts drowsiness status</p>
                    </div>
                </div>

                <div class="workflow-arrow">→</div>

                <div class="workflow-step">
                    <div class="step-number">5</div>
                    <div class="step-content">
                        <h3>Emergency Alert</h3>
                        <p>Triggers alarm, SMS, and notifications</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Statistics Section -->
    <section class="statistics">
        <div class="container">
            <h2 class="section-title">Trusted by Safety Leaders</h2>

            <div class="stats-grid">
                <div class="stat-card glass-card">
                    <div class="stat-number">98.5%</div>
                    <p class="stat-label">Detection Accuracy</p>
                </div>

                <div class="stat-card glass-card">
                    <div class="stat-number">24/7</div>
                    <p class="stat-label">Continuous Monitoring</p>
                </div>

                <div class="stat-card glass-card">
                    <div class="stat-number">&lt;100ms</div>
                    <p class="stat-label">Alert Response Time</p>
                </div>

                <div class="stat-card glass-card">
                    <div class="stat-number">∞</div>
                    <p class="stat-label">Alert History Records</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Technology Stack Section -->
    <section class="tech-stack">
        <div class="container">
            <h2 class="section-title">Built With Industry Leaders</h2>

            <div class="tech-grid">
                <div class="tech-item">
                    <h3>Frontend</h3>
                    <ul>
                        <li>HTML5 & CSS3</li>
                        <li>Vanilla JavaScript</li>
                        <li>EJS Templating</li>
                    </ul>
                </div>

                <div class="tech-item">
                    <h3>Backend</h3>
                    <ul>
                        <li>Node.js</li>
                        <li>Express.js</li>
                        <li>MySQL Database</li>
                    </ul>
                </div>

                <div class="tech-item">
                    <h3>AI/ML</h3>
                    <ul>
                        <li>Python</li>
                        <li>TensorFlow/Keras</li>
                        <li>OpenCV</li>
                    </ul>
                </div>

                <div class="tech-item">
                    <h3>Integration</h3>
                    <ul>
                        <li>Google Maps API</li>
                        <li>Twilio SMS</li>
                        <li>WebSocket Real-time</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
        <div class="container">
            <div class="cta-content">
                <h2>Ready to Enhance Driver Safety?</h2>
                <p>Start monitoring your drivers with advanced AI technology</p>
                <div class="cta-buttons">
                    <a href="/dashboard?driver_id=DRIVER_001" class="btn btn-lg btn-primary">
                        Get Started Now
                    </a>
                    <a href="/about" class="btn btn-lg btn-outline">
                        Learn More
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <h3>DriveAlert</h3>
                    <p>Advanced driver safety monitoring system powered by AI</p>
                </div>

                <div class="footer-section">
                    <h4>Quick Links</h4>
                    <ul>
                        <li><a href="/">Home</a></li>
                        <li><a href="/about">About</a></li>
                        <li><a href="/dashboard">Dashboard</a></li>
                        <li><a href="/alerts">Alerts</a></li>
                    </ul>
                </div>

                <div class="footer-section">
                    <h4>Features</h4>
                    <ul>
                        <li><a href="#">Real-time Detection</a></li>
                        <li><a href="#">GPS Tracking</a></li>
                        <li><a href="#">Live Analytics</a></li>
                        <li><a href="#">SMS Alerts</a></li>
                    </ul>
                </div>

                <div class="footer-section">
                    <h4>Follow Us</h4>
                    <div class="social-links">
                        <a href="#"><i class="fab fa-facebook"></i></a>
                        <a href="#"><i class="fab fa-twitter"></i></a>
                        <a href="#"><i class="fab fa-linkedin"></i></a>
                        <a href="#"><i class="fab fa-github"></i></a>
                    </div>
                </div>
            </div>

            <div class="footer-bottom">
                <p>&copy; 2024 DriveAlert. All rights reserved. | <a href="#">Privacy Policy</a> | <a href="#">Terms of Service</a></p>
            </div>
        </div>
    </footer>

    <script src="/js/home.js"></script>
</body>
</html>
