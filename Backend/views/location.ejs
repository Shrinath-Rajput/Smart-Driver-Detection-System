<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Driver Location - Smart Detection System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
    <div class="location-container">
        <div class="location-card">
            <h1>
                <i class="fas fa-map-marker-alt"></i>
                Driver Location
            </h1>

            <div class="location-info">
                <div class="info-row">
                    <span class="info-label">Latitude:</span>
                    <span class="info-value"><%= latitude || 'N/A' %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">Longitude:</span>
                    <span class="info-value"><%= longitude || 'N/A' %></span>
                </div>
                <% if (lastUpdated) { %>
                <div class="info-row">
                    <span class="info-label">Last Updated:</span>
                    <span class="info-value"><%= new Date(lastUpdated).toLocaleString() %></span>
                </div>
                <% } %>
            </div>

            <% if (mapsLink) { %>
            <a href="<%= mapsLink %>" target="_blank" class="map-button">
                <i class="fas fa-external-link-alt"></i> View on Google Maps
            </a>
            <% } else { %>
            <div style="background: #f9f9f9; padding: 15px; border-radius: 10px; text-align: center; color: #999; margin-bottom: 10px;">
                Location data not available
            </div>
            <% } %>

            <a href="/dashboard" class="back-button">
                <i class="fas fa-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>
</body>
</html>