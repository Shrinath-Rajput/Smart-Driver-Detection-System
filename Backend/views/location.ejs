<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Driver Location - Smart Detection System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            padding: 40px 20px;
        }

        .location-container {
            max-width: 600px;
            margin: 0 auto;
        }

        .location-card {
            background: white;
            border-radius: 15px;
            padding: 40px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
        }

        .location-card h1 {
            color: #667eea;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 30px;
        }

        .location-info {
            background: #f9f9f9;
            padding: 20px;
            border-radius: 10px;
            margin-bottom: 25px;
        }

        .info-row {
            display: flex;
            justify-content: space-between;
            padding: 12px 0;
            border-bottom: 1px solid #eee;
        }

        .info-row:last-child {
            border-bottom: none;
        }

        .info-label {
            font-weight: 600;
            color: #667eea;
        }

        .info-value {
            color: #333;
            font-family: 'Courier New', monospace;
        }

        .map-button {
            display: block;
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            text-decoration: none;
            text-align: center;
            border-radius: 10px;
            font-weight: 600;
            transition: transform 0.3s;
            margin-bottom: 10px;
        }

        .map-button:hover {
            transform: scale(1.05);
            color: white;
            text-decoration: none;
        }

        .back-button {
            display: block;
            width: 100%;
            padding: 15px;
            background: #e0e0e0;
            color: #333;
            text-decoration: none;
            text-align: center;
            border-radius: 10px;
            font-weight: 600;
            transition: transform 0.3s;
        }

        .back-button:hover {
            transform: scale(1.05);
            color: #333;
            text-decoration: none;
        }
    </style>
</head>
<body>
    <div class="location-container">
        <div class="location-card">
            <h1>
                <i class="fas fa-map-marker-alt"></i>
                Driver Location
            </h1>

            <div class="location-info">
                <div class="info-row">
                    <span class="info-label">Latitude:</span>
                    <span class="info-value"><%= latitude || 'N/A' %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">Longitude:</span>
                    <span class="info-value"><%= longitude || 'N/A' %></span>
                </div>
                <% if (lastUpdated) { %>
                <div class="info-row">
                    <span class="info-label">Last Updated:</span>
                    <span class="info-value"><%= new Date(lastUpdated).toLocaleString() %></span>
                </div>
                <% } %>
            </div>

            <% if (mapsLink) { %>
            <a href="<%= mapsLink %>" target="_blank" class="map-button">
                <i class="fas fa-external-link-alt"></i> View on Google Maps
            </a>
            <% } else { %>
            <div style="background: #f9f9f9; padding: 15px; border-radius: 10px; text-align: center; color: #999; margin-bottom: 10px;">
                Location data not available
            </div>
            <% } %>

            <a href="/dashboard" class="back-button">
                <i class="fas fa-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>
</body>
</html>