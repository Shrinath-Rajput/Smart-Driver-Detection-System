<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Driver Drowsiness Detection</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            padding: 20px 0;
        }

        .container-fluid {
            max-width: 1400px;
            margin: 0 auto;
        }

        .header {
            background: rgba(255, 255, 255, 0.95);
            border-radius: 15px;
            padding: 30px;
            margin-bottom: 30px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
        }

        .header h1 {
            color: #667eea;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .header p {
            color: #666;
            margin: 10px 0 0 0;
            font-size: 0.95rem;
        }

        .status-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border-radius: 15px;
            padding: 40px 30px;
            margin-bottom: 30px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
            position: relative;
            overflow: hidden;
        }

        .status-card::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 300px;
            height: 300px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
        }

        .status-card-content {
            position: relative;
            z-index: 1;
        }

        .status-badge {
            display: inline-block;
            padding: 12px 30px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 50px;
            font-size: 0.9rem;
            font-weight: 600;
            margin-bottom: 20px;
            border: 2px solid rgba(255, 255, 255, 0.3);
        }

        .status-badge.awake {
            background: rgba(76, 175, 80, 0.3);
            border-color: rgba(76, 175, 80, 0.6);
            color: #4CAF50;
        }

        .status-badge.sleepy {
            background: rgba(244, 67, 54, 0.3);
            border-color: rgba(244, 67, 54, 0.6);
            color: #F44336;
        }

        .status-badge.offline {
            background: rgba(158, 158, 158, 0.3);
            border-color: rgba(158, 158, 158, 0.6);
            color: #9e9e9e;
        }

        .status-value {
            font-size: 3.5rem;
            font-weight: 700;
            margin: 20px 0;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .status-subtext {
            font-size: 1.1rem;
            opacity: 0.9;
            margin: 15px 0 0 0;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-box {
            background: white;
            border-radius: 15px;
            padding: 25px;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s, box-shadow 0.3s;
        }

        .stat-box:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.15);
        }

        .stat-icon {
            font-size: 2rem;
            color: #667eea;
            margin-bottom: 15px;
        }

        .stat-label {
            color: #999;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }

        .stat-value {
            font-size: 2rem;
            font-weight: 700;
            color: #333;
        }

        .alert-history {
            background: white;
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
            margin-bottom: 30px;
        }

        .alert-history h3 {
            color: #333;
            margin-bottom: 25px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .alert-item {
            padding: 15px 20px;
            border-left: 4px solid #667eea;
            background: #f9f9f9;
            margin-bottom: 12px;
            border-radius: 5px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .alert-item.drowsy {
            border-left-color: #F44336;
            background: rgba(244, 67, 54, 0.05);
        }

        .alert-time {
            color: #999;
            font-size: 0.85rem;
        }

        .alert-confidence {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 600;
        }

        .location-card {
            background: white;
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
        }

        .location-card h3 {
            color: #333;
            margin-bottom: 20px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        #map {
            width: 100%;
            height: 400px;
            border-radius: 10px;
            background: #e0e0e0;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #999;
        }

        .location-link {
            display: inline-block;
            margin-top: 15px;
            padding: 12px 25px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            text-decoration: none;
            border-radius: 25px;
            font-weight: 600;
            transition: transform 0.3s;
        }

        .location-link:hover {
            transform: scale(1.05);
            text-decoration: none;
            color: white;
        }

        .refresh-btn {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            padding: 12px 25px;
            border-radius: 25px;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.3s;
        }

        .refresh-btn:hover {
            transform: scale(1.05);
            color: white;
        }

        .refresh-btn i {
            margin-right: 8px;
        }

        .online-indicator {
            display: inline-block;
            width: 12px;
            height: 12px;
            background: #4CAF50;
            border-radius: 50%;
            margin-right: 8px;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% {
                opacity: 1;
            }
            50% {
                opacity: 0.5;
            }
        }

        .footer {
            text-align: center;
            color: rgba(255, 255, 255, 0.8);
            padding: 20px;
            margin-top: 30px;
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <!-- HEADER -->
        <div class="header">
            <h1>
                <i class="fas fa-car-side"></i>
                Smart Driver Drowsiness Detection System
            </h1>
            <p><span class="online-indicator"></span>Real-time Monitoring Dashboard</p>
            <button class="refresh-btn mt-3" onclick="refreshData()">
                <i class="fas fa-sync-alt"></i> Refresh Now
            </button>
        </div>

        <!-- MAIN STATUS CARD -->
        <div class="status-card">
            <div class="status-card-content">
                <div class="status-badge" id="statusBadge">Loading...</div>
                <div class="status-value" id="statusValue">--</div>
                <div class="status-subtext">
                    Confidence: <span id="confidenceValue">0%</span> | 
                    Driver: <span id="driverId"><%= driverId %></span>
                </div>
                <div class="status-subtext" style="font-size: 0.9rem; margin-top: 10px;">
                    Last Updated: <span id="lastUpdated">--</span>
                </div>
            </div>
        </div>

        <!-- STATISTICS GRID -->
        <div class="stats-grid">
            <div class="stat-box">
                <div class="stat-icon"><i class="fas fa-history"></i></div>
                <div class="stat-label">Total Alerts (24h)</div>
                <div class="stat-value" id="totalAlerts">0</div>
            </div>

            <div class="stat-box">
                <div class="stat-icon"><i class="fas fa-exclamation-triangle"></i></div>
                <div class="stat-label">Drowsiness Alerts</div>
                <div class="stat-value" id="drowsinessAlerts">0</div>
            </div>

            <div class="stat-box">
                <div class="stat-icon"><i class="fas fa-chart-line"></i></div>
                <div class="stat-label">Avg Confidence</div>
                <div class="stat-value" id="avgConfidence">0%</div>
            </div>
        </div>

        <!-- LOCATION CARD -->
        <div class="location-card" style="margin-bottom: 30px;">
            <h3>
                <i class="fas fa-map-marker-alt"></i>
                Last Known Location
            </h3>
            <div id="locationDisplay">
                <p style="color: #999;">Loading location...</p>
            </div>
        </div>

        <!-- ALERT HISTORY -->
        <div class="alert-history">
            <h3>
                <i class="fas fa-bell"></i>
                Recent Alerts
            </h3>
            <div id="alertsList">
                <p style="color: #999; text-align: center;">No recent alerts</p>
            </div>
        </div>

        <!-- FOOTER -->
        <div class="footer">
            <p>&copy; 2026 Smart Driver Drowsiness Detection System | Real-time Safety Monitoring</p>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Configuration
        const DRIVER_ID = '<%= driverId %>';
        const BACKEND_URL = 'http://localhost:5000';
        const REFRESH_INTERVAL = 5000; // 5 seconds
        let autoRefreshInterval;

        // Initialize data from server
        const initialData = {
            status: '<%= status %>',
            confidence: <%= confidence %>,
            confidencePercentage: '<%= confidencePercentage %>',
            latitude: <%= latitude || 'null' %>,
            longitude: <%= longitude || 'null' %>,
            lastUpdated: '<%= lastUpdated %>',
            recentAlerts: <%= JSON.stringify(recentAlerts || []) %>
        };

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            updateDashboardDisplay();
            autoRefreshInterval = setInterval(refreshData, REFRESH_INTERVAL);
        });

        // Refresh driver status
        async function refreshData() {
            try {
                const response = await fetch(`${BACKEND_URL}/api/v1/status?driver_id=${DRIVER_ID}`);
                if (!response.ok) throw new Error('Failed to fetch status');
                
                const result = await response.json();
                if (result.success && result.data) {
                    updateDashboardDisplay(result.data);
                }
            } catch (error) {
                console.error('Error refreshing data:', error);
            }
        }

        // Update dashboard display
        function updateDashboardDisplay(data = null) {
            const displayData = data || initialData;

            // Update status
            const statusValue = document.getElementById('statusValue');
            const statusBadge = document.getElementById('statusBadge');
            if (statusValue) statusValue.textContent = displayData.status;
            if (statusBadge) {
                statusBadge.textContent = displayData.status;
                statusBadge.className = `status-badge ${displayData.status.toLowerCase()}`;
            }

            // Update confidence
            const confidenceValue = document.getElementById('confidenceValue');
            if (confidenceValue) {
                confidenceValue.textContent = (typeof displayData.confidence === 'number' 
                    ? (displayData.confidence * 100).toFixed(2) 
                    : displayData.confidencePercentage) + '%';
            }

            // Update gauge
            updateGauge(displayData.confidence || 0);

            // Update last updated time
            const lastUpdated = document.getElementById('lastUpdated');
            if (lastUpdated && displayData.lastUpdated) {
                const date = new Date(displayData.lastUpdated);
                lastUpdated.textContent = date.toLocaleTimeString();
            }

            // Update location
            if (displayData.latitude && displayData.longitude) {
                const locationDisplay = document.getElementById('locationDisplay');
                const mapsLink = `https://maps.google.com/?q=${displayData.latitude},${displayData.longitude}`;
                if (locationDisplay) {
                    locationDisplay.innerHTML = `
                        <p style="margin-bottom: 15px;">
                            <strong>Latitude:</strong> ${(displayData.latitude).toFixed(6)}<br>
                            <strong>Longitude:</strong> ${(displayData.longitude).toFixed(6)}
                        </p>
                        <a href="${mapsLink}" target="_blank" class="location-link">
                            <i class="fas fa-external-link-alt"></i> View on Google Maps
                        </a>
                    `;
            }

            // Update alert history
            const alertsList = document.getElementById('alertsList');
            if (alertsList) {
                if (displayData.recentAlerts && displayData.recentAlerts.length > 0) {
                    let alertsHTML = '';
                    displayData.recentAlerts.forEach(alert => {
                        const alertTime = new Date(alert.alert_time).toLocaleTimeString();
                        const alertClass = alert.status === 'SLEEPY' ? 'drowsy' : '';
                        const confidence = typeof alert.confidence === 'number' 
                            ? (alert.confidence * 100).toFixed(0) 
                            : '0';
                        alertsHTML += `
                            <div class="alert-item ${alertClass}">
                                <div>
                                    <strong>${alert.status}</strong>
                                    <div class="alert-time">${alertTime}</div>
                                </div>
                                <div class="alert-confidence">${confidence}%</div>
                            </div>
                        `;
                    });
                    alertsList.innerHTML = alertsHTML;
                } else {
                    alertsList.innerHTML = '<div style="padding: 20px; text-align: center; color: #999;">No recent alerts</div>';
                }
            }
        }

        // Gauge update function
        function updateGauge(confidence) {
            const gauge = document.getElementById('confidenceGauge');
            if (gauge) {
                const circumference = 2 * Math.PI * 45;
                const offset = circumference - (confidence * circumference);
                gauge.style.strokeDashoffset = offset;
            }
        }

        // Stop auto-refresh when leaving page
        window.addEventListener('beforeunload', () => {
            clearInterval(autoRefreshInterval);
        });
    </script>
</body>
</html>