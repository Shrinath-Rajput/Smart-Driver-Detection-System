<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Dashboard — Smart Driver Drowsiness Detection</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <script src="https://kit.fontawesome.com/a2d9b6f3b0.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <style>
        :root { font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial; }
    </style>
</head>
<body>
    <%- include('partials/navbar') %>

    <main class="dashboard-container page-wrapper">
        <!-- LEFT SIDEBAR -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <h2>Overview</h2>
                <div class="driver-id">Driver: <strong id="driverId"><%= driverId %></strong></div>
            </div>

            <nav class="sidebar-menu">
                <a class="menu-item active"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
                <a class="menu-item"><i class="fas fa-map-marked-alt"></i> Live Map</a>
                <a class="menu-item"><i class="fas fa-bell"></i> Alerts</a>
                <a class="menu-item"><i class="fas fa-cogs"></i> Settings</a>
            </nav>

            <div class="sidebar-footer">
                <div class="last-update">Last: <span id="lastUpdated">--</span></div>
                <div class="small muted">Auto-refresh every 5s</div>
            </div>
        </aside>

        <!-- MAIN CONTENT -->
        <section class="dashboard-main">
            <header class="dashboard-header">
                <div>
                    <h1>Smart Driver Drowsiness — Dashboard</h1>
                    <div class="timestamp">Real-time Monitoring</div>
                </div>
                <div class="header-actions">
                    <button class="btn btn-sm btn-ghost refresh-btn" onclick="refreshData()"><i class="fas fa-sync-alt"></i> Refresh</button>
                    <div class="timestamp">Driver: <strong><%= driverId %></strong></div>
                </div>
            </header>

            <!-- Top row: status/indicators -->
            <div class="cards-grid">
                <div class="card" aria-live="polite">
                    <div class="card-header">
                        <h3>Driver Status</h3>
                        <div class="badge-refresh">Live</div>
                    </div>
                    <div class="card-body">
                        <div class="status-display">
                            <div class="status-circle" id="statusCircle" data-status="LOADING"> <i class="fas fa-user"></i> </div>
                            <div class="status-info">
                                <div class="status-value" id="statusValue">Loading...</div>
                                <div class="status-label">Current State</div>
                                <div class="status-details">
                                    <div class="detail-item"><div class="detail-label">Confidence</div><div class="detail-value" id="confidenceValue">0%</div></div>
                                    <div class="detail-item"><div class="detail-label">Alarms</div><div class="detail-value" id="alarmCount">0</div></div>
                                </div>
                            </div>
                            <div style="width:140px">
                                <div class="circular-gauge" title="Confidence">
                                    <svg viewBox="0 0 120 120">
                                        <defs>
                                            <linearGradient id="gaugeGradient" x1="0%" x2="100%">
                                                <stop offset="0%" stop-color="#6EE7B7" />
                                                <stop offset="100%" stop-color="#60A5FA" />
                                            </linearGradient>
                                        </defs>
                                        <circle class="gauge-background" cx="60" cy="60" r="45" />
                                        <circle id="confidenceGauge" class="gauge-value" cx="60" cy="60" r="45" stroke-dasharray="283" stroke-dashoffset="283" />
                                    </svg>
                                    <div class="gauge-text"><div class="gauge-value-display" id="gaugeText">0%</div><div class="gauge-label">Confidence</div></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header"><h3>Alarms</h3><div class="badge-refresh">Live</div></div>
                    <div class="card-body">
                        <div class="alert-status-info">
                            <div class="status-indicator" id="alarmIndicator"><span class="pulse"></span><i class="fas fa-bell"></i></div>
                            <div class="alert-status-text">
                                <strong id="alarmStatus">No Active Alarm</strong>
                                <p id="alarmSummary">All systems normal</p>
                            </div>
                        </div>
                        <div style="margin-top:1rem">
                            <div class="performance-metrics">
                                <div class="metric">
                                    <div class="metric-label">Sleep Counter (today)</div>
                                    <div class="metric-bar"><div id="sleepFill" class="metric-fill" style="width:0%"></div></div>
                                </div>
                                <div class="metric">
                                    <div class="metric-label">Model Confidence</div>
                                    <div class="metric-bar"><div id="modelFill" class="metric-fill" style="width:0%"></div></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header"><h3>Sleep Counter</h3></div>
                    <div class="card-body centered">
                        <div style="font-size:28px;font-weight:700" id="sleepCount">0</div>
                        <div style="opacity:0.7;margin-top:6px">Total sleep events today</div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header"><h3>Confidence</h3></div>
                    <div class="card-body centered">
                        <div style="font-size:28px;font-weight:700" id="confidencePct">0%</div>
                        <div style="opacity:0.7;margin-top:6px">Average confidence (rolling)</div>
                    </div>
                </div>
            </div>

            <!-- Second row: map and driver info -->
            <div class="cards-grid">
                <div class="card">
                    <div class="card-header"><h3>Live GPS</h3></div>
                    <div class="card-body location-info">
                        <div class="coordinates" id="locationDisplay">No location</div>
                        <div id="mapPreview" style="height:180px;background:rgba(255,255,255,0.02);border-radius:8px;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,0.6)">Map preview</div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header"><h3>Google Maps</h3></div>
                    <div class="card-body centered">
                        <a id="mapLink" href="#" target="_blank" class="btn btn-ghost">Open in Google Maps</a>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header"><h3>Driver Information</h3></div>
                    <div class="card-body">
                        <div class="stats-list">
                            <div class="stat-row"><div class="stat-name">Name</div><div class="stat-value">--</div></div>
                            <div class="stat-row"><div class="stat-name">Vehicle</div><div class="stat-value">--</div></div>
                            <div class="stat-row"><div class="stat-name">Route</div><div class="stat-value">--</div></div>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header"><h3>Model Accuracy</h3></div>
                    <div class="card-body">
                        <div class="cards-grid">
                            <div class="card small"><div class="card-body centered"><div style="font-weight:700;font-size:20px">98.55%</div><div style="opacity:0.75">Test Accuracy</div></div></div>
                            <div class="card small"><div class="card-body centered"><div style="font-weight:700;font-size:20px">98.49%</div><div style="opacity:0.75">Validation</div></div></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Third row: alerts table -->
            <section class="section">
                <div class="section-header">
                    <h2>Recent Alerts</h2>
                    <a class="view-all" href="/alerts">View all</a>
                </div>
                <div class="recent-alerts card">
                    <div class="alerts-table" id="alertsTable">
                        <div class="table-header">
                            <div>Time</div>
                            <div>Type</div>
                            <div>Confidence</div>
                            <div>Status</div>
                            <div>Action</div>
                        </div>
                        <div id="alertsList" class="table-body empty-state"><i class="fas fa-bell"></i><div>No recent alerts</div></div>
                    </div>
                </div>
            </section>
        </section>

        <!-- RIGHT SIDEBAR -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <h2>Activity</h2>
            </div>
            <div class="card">
                <div class="card-body">
                    <h4>Recent Activity</h4>
                    <div class="stats-list" id="recentActivity"> <div style="opacity:0.6">No activity</div></div>
                </div>
            </div>

            <div class="card">
                <div class="card-body">
                    <h4>Emergency Notifications</h4>
                    <div id="emergencyList" class="empty-state"><i class="fas fa-ambulance"></i><div>No emergencies</div></div>
                </div>
            </div>

            <div class="card">
                <div class="card-body">
                    <h4>System Health</h4>
                    <div class="stat-row"><div class="stat-name">API</div><div class="stat-value">OK</div></div>
                    <div class="stat-row"><div class="stat-name">DB</div><div class="stat-value">OK</div></div>
                </div>
            </div>
        </aside>
    </main>

    <script>
        // Configuration
        const DRIVER_ID = '<%= driverId %>';
        const BACKEND_URL = 'http://localhost:5000';
        const REFRESH_INTERVAL = 5000; // 5 seconds
        let autoRefreshInterval;

        // Initialize data from server
        const initialData = {
            status: '<%= status %>',
            confidence: <%= confidence %>,
            confidencePercentage: '<%= confidencePercentage %>',
            latitude: <%= latitude || 'null' %>,
            longitude: <%= longitude || 'null' %>,
            lastUpdated: '<%= lastUpdated %>',
            recentAlerts: <%= JSON.stringify(recentAlerts || []) %>
        };

        document.addEventListener('DOMContentLoaded', () => {
            updateDashboardDisplay();
            autoRefreshInterval = setInterval(refreshData, REFRESH_INTERVAL);
        });

        async function refreshData() {
            try {
                const response = await fetch(`${BACKEND_URL}/api/v1/status?driver_id=${DRIVER_ID}`);
                if (!response.ok) throw new Error('Failed to fetch status');
                const result = await response.json();
                if (result.success && result.data) updateDashboardDisplay(result.data);
            } catch (error) { console.error('Error refreshing data:', error); }
        }

        function updateDashboardDisplay(data = null) {
            const displayData = data || initialData;

            // Status
            const statusValue = document.getElementById('statusValue');
            const statusCircle = document.getElementById('statusCircle');
            const statusBadge = document.getElementById('statusBadge');
            if (statusValue) statusValue.textContent = displayData.status || '--';
            if (statusCircle) statusCircle.dataset.status = (displayData.status || 'LOADING').toUpperCase();

            // Confidence
            const confPct = (typeof displayData.confidence === 'number') ? (displayData.confidence * 100) : (displayData.confidencePercentage || 0);
            const confEl = document.getElementById('confidenceValue');
            if (confEl) confEl.textContent = Math.round(confPct) + '%';
            const gaugeText = document.getElementById('gaugeText');
            if (gaugeText) gaugeText.textContent = Math.round(confPct) + '%';
            const confFill = document.getElementById('modelFill'); if (confFill) confFill.style.width = Math.min(100, Math.round(confPct)) + '%';
            const confidencePct = document.getElementById('confidencePct'); if (confidencePct) confidencePct.textContent = Math.round(confPct) + '%';

            // Sleep counter and alarms
            document.getElementById('sleepCount').textContent = displayData.sleepCount || 0;
            document.getElementById('alarmCount').textContent = displayData.alarmCount || 0;

            // Update last updated
            const lastUpdated = document.getElementById('lastUpdated');
            if (lastUpdated && displayData.lastUpdated) lastUpdated.textContent = new Date(displayData.lastUpdated).toLocaleTimeString();

            // Location
            if (displayData.latitude && displayData.longitude) {
                const locationDisplay = document.getElementById('locationDisplay');
                const mapLink = document.getElementById('mapLink');
                if (locationDisplay) locationDisplay.innerHTML = `<strong>Lat:</strong> ${displayData.latitude.toFixed(6)} <br><strong>Lng:</strong> ${displayData.longitude.toFixed(6)}`;
                if (mapLink) mapLink.href = `https://maps.google.com/?q=${displayData.latitude},${displayData.longitude}`;
            }

            // Alerts
            const alertsList = document.getElementById('alertsList');
            if (alertsList) {
                if (displayData.recentAlerts && displayData.recentAlerts.length > 0) {
                    let html = '';
                    displayData.recentAlerts.forEach(alert => {
                        const when = new Date(alert.alert_time).toLocaleTimeString();
                        const conf = (typeof alert.confidence === 'number') ? Math.round(alert.confidence * 100) + '%' : '0%';
                        const badgeClass = alert.status === 'SLEEPY' ? 'badge-drowsiness' : (alert.status === 'EMERGENCY' ? 'badge-emergency' : 'badge-awake');
                        html += `<div class="table-row"><div class="col-time">${when}</div><div class="col-type">${alert.type||alert.status}</div><div class="col-confidence">${conf}</div><div class="col-status"><span class="badge ${badgeClass}">${alert.status}</span></div><div class="col-action"><a class="btn btn-sm" href="#">View</a></div></div>`;
                    });
                    alertsList.outerHTML = `<div id="alertsList">${html}</div>`;
                } else {
                    alertsList.innerHTML = '<div class="empty-state"><i class="fas fa-bell"></i><div>No recent alerts</div></div>';
                }
            }
        }

        // Gauge drawing
        function updateGauge(confidence) {
            const gauge = document.getElementById('confidenceGauge');
            if (!gauge) return;
            const circumference = 2 * Math.PI * 45;
            const pct = Math.min(1, Math.max(0, confidence || 0));
            const offset = circumference - (pct * circumference);
            gauge.style.strokeDashoffset = offset;
        }

        window.addEventListener('beforeunload', () => clearInterval(autoRefreshInterval));
    </script>
</body>
</html>